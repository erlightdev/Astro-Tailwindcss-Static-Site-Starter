---
import BaseLayout from "../layouts/BaseLayout.astro";
import SwiperSlider from "../components/SwiperSlider.astro";
---

<BaseLayout title="Westman">
  <main class="max-w-4xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold text-center text-gray-900 mb-3">Astro + Tailwind + Swiper</h1>
    <p class="text-center text-gray-500 mb-12">Swiper slider bundled into <code class="bg-gray-100 px-1.5 py-0.5 rounded text-sm">assets/vendor/</code></p>
    <SwiperSlider />
  </main>
</BaseLayout>
